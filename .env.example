# =================================================================
# CLOUD DATABASE CONFIGURATION (PostgreSQL)
# =================================================================

# The hostname or IP of your PostgreSQL server
DB_HOST=app.ball-b.de

# Standard PostgreSQL port is 5432
DB_PORT=5432

# Database user authorized to update gateway_inventory
DB_USER=gateway_admin

# Database password
DB_PASSWORD=your_secure_password

# The target database name
DB_NAME=postgres

# --- ADVANCED DB OPTION ---
# You can provide a full connection string instead of individual fields above:
# DATABASE_URL=postgresql://gateway_admin:password@app.ball-b.de:5432/postgres


# =================================================================
# LOCAL WEB-APP CONFIGURATION
# =================================================================

# The port on which the local provisioner UI will run (default is 5000)
PORT=5000
HOST=0.0.0.0
FLASK_DEBUG=true
OPEN_BROWSER=true


# =================================================================
# MILESIGHT GATEWAY CONFIGURATION
# =================================================================

# The local IP address of the Gateway (default is 192.168.1.1)
GATEWAY_IP=192.168.1.1

# The API username for the Gateway (default is admin)
GATEWAY_USER=admin

# The API password for the Gateway (default is password)
GATEWAY_PASSWORD=password


# =================================================================
# CHIRPSTACK CONFIGURATION
# =================================================================

# Base URL of ChirpStack (used to build /api/gateways)
CHIRPSTACK_URL=https://chirpstack.example.com

# API token for ChirpStack (Bearer)
CHIRPSTACK_API_TOKEN=your_chirpstack_token

# Tenant ID for gateway creation
CHIRPSTACK_TENANT_ID=your_chirpstack_tenant_id

# Gateway stats interval (seconds)
CHIRPSTACK_STATS_INTERVAL_SECS=30


# =================================================================
# MILESIGHT DEVELOPER PLATFORM
# =================================================================

# Base URL for Milesight OpenAPI
MILESIGHT_URL=https://eu-openapi.milesight.com

# OAuth client id / secret
MILESIGHT_CLIENT_ID=1f506e2c-9e84-4869-a5a9-288f3bd10801
MILESIGHT_CLIENT_SECRET=your_milesight_client_secret

# Optional override for token URL (if different)
MILESIGHT_TOKEN_URL=


# =================================================================
# AUTH CONFIGURATION
# =================================================================
# Change in production.
JWT_SECRET=change-this-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRES_HOURS=24


# =================================================================
# VPN PING (optional cloud proxy)
# =================================================================
# Leave empty to ping locally from current app runtime.
# Set to your cloud API base URL when local machine cannot reach VPN.
VPN_PING_PROVIDER_URL=

# Shared token for /api/network/ping-service (set on both local caller and cloud service).
VPN_PING_SERVICE_TOKEN=
